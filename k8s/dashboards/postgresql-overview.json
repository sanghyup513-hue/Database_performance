{
  "uid": "pg-bench-overview",
  "title": "PostgreSQL (XcruzDB) - Benchmark Overview",
  "tags": ["db-benchmark", "postgresql"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "role",
        "label": "Instance role",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
        "query": { "query": "label_values(pg_up, instance_role)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Instances Up",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }], "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "pg_up{instance_role=~\"$role\"}", "legendFormat": "{{instance_role}}" }]
    },
    {
      "type": "stat",
      "title": "Active Backends (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum by (instance_role) (pg_stat_db_numbackends{instance_role=~\"$role\"})", "legendFormat": "{{instance_role}}" }]
    },
    {
      "type": "stat",
      "title": "Transactions / sec (commit)",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "thresholds": { "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum by (instance_role) (rate(pg_stat_db_xact_commit{instance_role=~\"$role\"}[$__rate_interval]))", "legendFormat": "{{instance_role}}" }]
    },
    {
      "type": "timeseries",
      "title": "Transactions / sec (commit vs rollback)",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum by (instance_role) (rate(pg_stat_db_xact_commit{instance_role=~\"$role\"}[$__rate_interval]))", "legendFormat": "commit - {{instance_role}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum by (instance_role) (rate(pg_stat_db_xact_rollback{instance_role=~\"$role\"}[$__rate_interval]))", "legendFormat": "rollback - {{instance_role}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connections by state",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "stacking": { "mode": "normal" }, "fillOpacity": 30, "showPoints": "never" } }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum by (state) (pg_connections_count{instance_role=~\"$role\"})", "legendFormat": "{{state}}" }]
    },
    {
      "type": "timeseries",
      "title": "Buffer cache hit ratio (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "100 * sum by (instance_role) (rate(pg_stat_db_blks_hit{instance_role=~\"$role\"}[$__rate_interval])) / clamp_min(sum by (instance_role) (rate(pg_stat_db_blks_hit{instance_role=~\"$role\"}[$__rate_interval]) + rate(pg_stat_db_blks_read{instance_role=~\"$role\"}[$__rate_interval])), 1)", "legendFormat": "{{instance_role}}" }]
    },
    {
      "type": "timeseries",
      "title": "Tuple operations / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum (rate(pg_stat_db_tup_inserted{instance_role=~\"$role\"}[$__rate_interval]))", "legendFormat": "inserted" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum (rate(pg_stat_db_tup_updated{instance_role=~\"$role\"}[$__rate_interval]))", "legendFormat": "updated" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum (rate(pg_stat_db_tup_deleted{instance_role=~\"$role\"}[$__rate_interval]))", "legendFormat": "deleted" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum (rate(pg_stat_db_tup_fetched{instance_role=~\"$role\"}[$__rate_interval]))", "legendFormat": "fetched" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Locks by mode",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "stacking": { "mode": "normal" }, "fillOpacity": 30, "showPoints": "never" } }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "sum by (mode) (pg_locks_count{instance_role=~\"$role\"})", "legendFormat": "{{mode}}" }]
    },
    {
      "type": "timeseries",
      "title": "Top database sizes (coordinator)",
      "datasource": { "type": "prometheus", "uid": "prometheus-bench" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus-bench" }, "expr": "topk(10, pg_database_size_bytes{instance_role=\"coordinator\"})", "legendFormat": "{{datname}}" }]
    }
  ]
}
